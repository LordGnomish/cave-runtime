{
  "title": "Cave / cave-vulns",
  "uid": "cave-vulns",
  "tags": [
    "cave",
    "observability",
    "cave-vulns"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0
      },
      {
        "name": "tenant",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(vulns_total{job=\"cave-vulns\"}, tenant_id)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(vulns_total{job=\"cave-vulns\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "description": "Vulnerability tracking \u2014 request throughput."
    },
    {
      "id": 2,
      "title": "Error rate (4xx + 5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(vulns_total{job=\"cave-vulns\",code=~\"4..|5..\"}[5m])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "description": "Errors broken down by HTTP class."
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.50, sum(rate(vulns_duration_seconds_bucket{job=\"cave-vulns\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum(rate(vulns_duration_seconds_bucket{job=\"cave-vulns\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.99, sum(rate(vulns_duration_seconds_bucket{job=\"cave-vulns\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "description": "RED triad \u2014 duration percentiles."
    },
    {
      "id": 4,
      "title": "Inflight requests (saturation)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(vulns_inflight_requests{job=\"cave-vulns\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Concurrent in-progress requests."
    },
    {
      "id": 5,
      "title": "CPU utilization",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(process_cpu_seconds_total{job=\"cave-vulns\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "description": "Per-instance CPU."
    },
    {
      "id": 6,
      "title": "Memory (RSS)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "process_resident_memory_bytes{job=\"cave-vulns\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "description": "Resident set size."
    },
    {
      "id": 7,
      "title": "Active goroutines / tasks",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "go_goroutines{job=\"cave-vulns\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      },
      "description": "Goroutine count proxies for backpressure."
    },
    {
      "id": 8,
      "title": "Tenant cardinality",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(count by (tenant_id) (vulns_total{job=\"cave-vulns\"}))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Number of distinct tenants emitting traffic."
    },
    {
      "id": 9,
      "title": "Top-10 tenants by request volume",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "topk(10, sum(rate(vulns_total{job=\"cave-vulns\"}[5m])) by (tenant_id))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "description": "Hot-tenant table \u2014 feeds throttle / inhibit decisions."
    },
    {
      "id": 10,
      "title": "Health probe (up)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "min(up{job=\"cave-vulns\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "0 = at least one instance failing the scrape."
    },
    {
      "id": 11,
      "title": "Active findings by severity",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"x": 0, "y": 40, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(vulns_findings_total{state=\"active\"}) by (severity)",
         "legendFormat": "{{severity}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "description": "Live active-finding counts split by Critical/High/Medium/Low/Info."
    },
    {
      "id": 12,
      "title": "SLA breach count",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"x": 12, "y": 40, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(vulns_sla_breached_total)",
         "legendFormat": "breached", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}, "overrides": []},
      "description": "Findings past their SLA deadline. Charter target: 0."
    },
    {
      "id": 13,
      "title": "Scan import rate (by scanner)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"x": 0, "y": 48, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(rate(vulns_scan_imports_total[5m])) by (scan_type)",
         "legendFormat": "{{scan_type}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "description": "Per-parser import throughput (Bandit/Trivy/ZAP/Semgrep/SARIF/Snyk/Nuclei)."
    },
    {
      "id": 14,
      "title": "Dedup hit rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"x": 12, "y": 48, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(rate(vulns_dedup_collapsed_total[5m])) / clamp_min(sum(rate(vulns_dedup_input_total[5m])), 1)",
         "legendFormat": "collapse %", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "description": "Fraction of ingested findings collapsed by dedup over 5m."
    },
    {
      "id": 15,
      "title": "Top vulnerable products",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"x": 0, "y": 56, "w": 12, "h": 8},
      "targets": [
        {"expr": "topk(10, sum(vulns_findings_total{state=\"active\"}) by (product))",
         "legendFormat": "{{product}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "description": "Products with most active findings."
    },
    {
      "id": 16,
      "title": "Risk-acceptances active vs expired",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"x": 12, "y": 56, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(vulns_risk_acceptance_active_total)", "legendFormat": "active", "refId": "A"},
        {"expr": "sum(increase(vulns_risk_acceptance_expired_total[1h]))", "legendFormat": "expired/h", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "description": "Live RA pressure + hourly expiry rate."
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "Vulnerability tracking"
}
